# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Local GPTQ model (optional — requires GPU + auto-gptq + transformers)
# Set to a HuggingFace repo ID or an absolute local path.
# Example: TheBloke/WizardCoder-15B-1.0-GPTQ
GPTQ_MODEL_PATH=
GPTQ_USE_TRITON=false

# Pinecone (Vector Database)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=your_pinecone_environment

# Database
POSTGRES_DB=quran_ai
POSTGRES_USER=quran_user
POSTGRES_PASSWORD=secure_password_here
DATABASE_URL=postgresql://quran_user:secure_password_here@db:5432/quran_ai

# Redis
REDIS_URL=redis://redis:6379/0

# App
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
